; ============================================================
; Test projects use underscored method names by convention
; (Subject_State_ExpectedBehavior). Disable the corresponding
; analyzer rule. IDE0005 demoted to suggestion to avoid false
; positives from global usings declared in a separate file.
;
; CA1873 (LoggerMessage performance) is a production hot-path
; concern that doesn't apply when we're verifying Mock<ILogger>
; invocations in tests.
; ============================================================

[*.cs]

dotnet_diagnostic.CA1707.severity = none
dotnet_diagnostic.IDE0005.severity = suggestion
dotnet_diagnostic.CA1873.severity = none